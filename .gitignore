# Root .gitignore for the whole project

# dependencies
node_modules/
client/node_modules/
server/node_modules/
.pnp
.pnp.*

# package manager files
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# environment files
.env
.env.*
client/.env
client/.env.*
server/.env
server/.env.*
!.env.example
!client/.env.example
!server/.env.example

# build output
.next/
client/.next/
out/
build/
dist/
coverage/

# deployment
.vercel/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# system files
.DS_Store
Thumbs.db
*.pem

# typescript
*.tsbuildinfo
next-env.d.ts
